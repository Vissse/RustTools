# PostHog analytics. Copy to `.env.local` for local dev (gitignored via *.local),
# and set the same vars in Vercel → Settings → Environment Variables for
# production (Next inlines NEXT_PUBLIC_* at build time).
#
# Analytics is fully disabled when NEXT_PUBLIC_POSTHOG_KEY is unset.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
