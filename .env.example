# PostHog analytics. Copy to `.env.local` for local dev (gitignored via *.local),
# and set the same vars in Cloudflare Pages → Settings → Environment variables
# for production (Vite inlines VITE_* at build time).
#
# Analytics is fully disabled when VITE_POSTHOG_KEY is unset.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://eu.i.posthog.com
